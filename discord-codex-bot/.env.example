DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_test_server_id

# Comma-separated Discord user IDs allowed to run Codex.
ALLOWED_USER_IDS=123456789012345678

# Absolute path to the VtuberCamera_KMP_ver repository on this machine.
REPO_VTUBERCAMERA_KMP_VER=/path/to/VtuberCamera_KMP_ver

# Optional. Forwarded to codex exec when present in this process environment.
CODEX_API_KEY=

# Optional. Forwarded for workflows that use gh inside Codex.
GITHUB_TOKEN=
